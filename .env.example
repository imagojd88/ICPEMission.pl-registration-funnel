# ── Backend (api) ─────────────────────────────────────────
DATABASE_URL=postgresql://icpe:icpe@localhost:5432/icpe?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-dev-secret
JWT_REFRESH_SECRET=change-me-dev-refresh
# token serwisowy dla Personal OS (admin:read[,admin:write])
SERVICE_TOKEN=dev-personal-os-token
PORT=3000

# Płatności (adaptery) — w dev używamy trybu mock
PAYMENTS_MODE=mock           # mock | live
P24_MERCHANT_ID=
P24_CRC=
STRIPE_SECRET_KEY=

# Mail (dev: log do konsoli)
MAIL_MODE=log                # log | smtp | resend
MAIL_FROM="ICPE Mission <noreply@icpemission.pl>"

# ── Frontend (app) ────────────────────────────────────────
VITE_API_URL=http://localhost:3000

# Skopiuj jako /var/www/icpe/.env i uzupełnij realnymi wartościami.

# ── Baza danych (PostgreSQL na tym samym serwerze) ───────────────────────────
DATABASE_URL=postgresql://icpe:SILNE_HASLO@localhost:5432/icpe?schema=public

# ── API ──────────────────────────────────────────────────────────────────────
PORT=3000
API_PREFIX=api                         # front i API pod jedną subdomeną
JWT_SECRET=ZMIEN_NA_DLUGI_LOSOWY_CIAG
JWT_REFRESH_SECRET=ZMIEN_NA_INNY_DLUGI_LOSOWY_CIAG
# token serwisowy dla Personal OS (admin:read[,admin:write])
SERVICE_TOKEN=ZMIEN_NA_DLUGI_LOSOWY_TOKEN

# CORS: front jest na tej samej subdomenie, więc wystarczy ona;
# dodaj origin Personal OS jeśli łączy się z innego hosta.
CORS_ORIGIN=https://rejestracja.icpemission.pl

# ── Płatności (gdy gotowe) ────────────────────────────────────────────────────
PAYMENTS_MODE=mock                     # mock | live
P24_MERCHANT_ID=
P24_CRC=
STRIPE_SECRET_KEY=

# ── Mail (gdy gotowe) ─────────────────────────────────────────────────────────
MAIL_MODE=log                          # log | smtp | resend
MAIL_FROM="ICPE Mission <noreply@icpemission.pl>"
# SMTP_HOST=...
# SMTP_USER=...
# SMTP_PASS=...

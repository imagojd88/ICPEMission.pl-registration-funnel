<style>
  /* Hero — crossfade dwóch zdjęć (powolny fade) */
  .hero-slide { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; opacity: 0; transition: opacity 1.8s ease-in-out; }
  .hero-slide.is-on { opacity: 1; }

  /* Rotator cytatów — płynny crossfade (nakładanie slajdów w gridzie, bez skoków wysokości) */
  .quotes { display: grid; grid-template-columns: 1fr; }
  .quote { grid-column: 1; grid-row: 1; opacity: 0; transition: opacity 1s ease-in-out; pointer-events: none; }
  .quote.is-active { opacity: 1; pointer-events: auto; }
  .quote-dots { grid-column: 1; grid-row: 2; display: flex; gap: 8px; margin-top: 26px; }
  .quote-dots button { width: 8px; height: 8px; border-radius: 50%; border: none; padding: 0; cursor: pointer; background: #c9bca9; transition: background .15s, transform .15s; }
  .quote-dots button.is-on { background: #c0603c; transform: scale(1.25); }

  /* Responsywność — składanie gridów do 1 kolumny na mobile */
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr !important; }
    .ethos { grid-template-columns: 1fr !important; gap: 44px !important; }
    .ethos-right { padding-top: 0 !important; }
    .triptych { grid-template-columns: 1fr !important; }
    .cards { grid-template-columns: 1fr 1fr !important; }
    .pillars { grid-template-columns: 1fr 1fr !important; }
    .footer-grid { grid-template-columns: 1fr !important; }
    .nav-links { display: none !important; }
    .map-head { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 560px) {
    .cards { grid-template-columns: 1fr !important; }
    .pillars { grid-template-columns: 1fr !important; }
    .stats { grid-template-columns: 1fr 1fr !important; }
    .hero-cta { flex-wrap: wrap; }
    /* zmniejsz duże nagłówki na mobile */
    #site-root h1 { font-size: 44px !important; }
    #site-root nav { padding: 20px 22px !important; }
    #site-root .hero { padding: 40px 22px !important; }
  }
</style>

<script is:inline>
  // E-mail antyspam: adres trzymany jako base64 w data-mail, mailto składany dopiero w JS,
  // więc w źródle HTML nie ma czytelnego wzorca „x@y" do zebrania przez boty.
  document.querySelectorAll('.js-mail').forEach((el) => {
    try {
      const email = atob(el.getAttribute('data-mail') || '');
      if (!email) return;
      const subj = el.getAttribute('data-subject');
      el.setAttribute('href', 'mailto:' + email + (subj ? '?subject=' + encodeURIComponent(subj) : ''));
      if (el.hasAttribute('data-showtext') && !el.textContent.trim()) el.textContent = email;
    } catch (e) { /* ignore */ }
  });

  // Hero: powolny crossfade między zdjęciami co 7s.
  document.querySelectorAll('[data-hero-slides]').forEach((box) => {
    const slides = Array.from(box.querySelectorAll('.hero-slide'));
    if (slides.length <= 1) return;
    let i = 0;
    setInterval(() => {
      slides[i].classList.remove('is-on');
      i = (i + 1) % slides.length;
      slides[i].classList.add('is-on');
    }, 7000);
  });

  // Rotator cytatów: pierwszy slajd (założyciele) startowy; auto-rotacja co 8s (gdy >1 cytat),
  // pauza na hover, kropki do ręcznego przełączania. Język działa przez CSS (data-pl/data-en).
  document.querySelectorAll('[data-quotes]').forEach((box) => {
    const slides = Array.from(box.querySelectorAll('.quote'));
    const dotsWrap = box.querySelector('.quote-dots');
    if (slides.length <= 1) { if (dotsWrap) dotsWrap.style.display = 'none'; return; }
    let idx = 0, timer;
    const dots = slides.map((_, i) => {
      const b = document.createElement('button');
      b.setAttribute('aria-label', 'Cytat ' + (i + 1));
      if (i === 0) b.classList.add('is-on');
      b.addEventListener('click', () => { show(i); restart(); });
      dotsWrap.appendChild(b);
      return b;
    });
    function show(i) {
      slides[idx].classList.remove('is-active'); dots[idx].classList.remove('is-on');
      idx = i;
      slides[idx].classList.add('is-active'); dots[idx].classList.add('is-on');
    }
    function next() { show((idx + 1) % slides.length); }
    function restart() { clearInterval(timer); timer = setInterval(next, 8000); }
    restart();
    box.addEventListener('mouseenter', () => clearInterval(timer));
    box.addEventListener('mouseleave', restart);
  });

  // Przełącznik języka PL/EN — ustawia data-lang na kontenerze (CSS steruje widocznością).
  const root = document.getElementById('site-root');
  document.querySelectorAll('[data-langbtn]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const lng = btn.getAttribute('data-langbtn');
      if (root && lng) {
        root.setAttribute('data-lang', lng);
        document.documentElement.setAttribute('lang', lng);
      }
    });
  });
</script>

---
import LandingLayout from '../layouts/LandingLayout.astro';
import WorldMap from '../components/WorldMap.astro';
import { getSettings, type HeroImage } from '../lib/api';

// Hero: konfiguracja z ustawień (Personal OS). Fallback = obecne 5 zdjęć, gdy API puste.
const FALLBACK_HERO_IMAGES: HeroImage[] = [
  { url: '/uploads/photo-1507692049790-de58290a4334.avif', position: 'center 40%', alt: 'Wieczór uwielbienia' },
  { url: '/uploads/hero_john.jpg', position: 'center 30%', alt: 'John Paul' },
  { url: '/uploads/hero_3.jpg', position: 'center 38%', alt: 'Wspólnota ICPE Mission' },
  { url: '/uploads/hero_4.jpg', position: 'center 45%', alt: 'Uwielbienie' },
  { url: '/uploads/hero_5.jpg', position: 'center 33%', alt: 'Modlitwa' },
];
const settings = await getSettings();
const heroCfg = settings.hero && Array.isArray(settings.hero.images) && settings.hero.images.length
  ? settings.hero
  : { rotate: true, defaultUrl: null, images: FALLBACK_HERO_IMAGES };
const heroRotate = heroCfg.rotate !== false;
let heroImages: HeroImage[] = heroCfg.images;
if (!heroRotate) {
  const def = heroImages.find((i) => i.url === heroCfg.defaultUrl) || heroImages[0];
  heroImages = def ? [def] : heroImages.slice(0, 1);
}
---

<LandingLayout>
  <div data-lang="pl" id="site-root" style="background:#F4EEE3; color:#241E1A; min-height:100vh; font-family:'Bricolage Grotesque',sans-serif;">
    <div style="max-width:1320px; margin:0 auto; background:#F4EEE3; overflow:hidden;">

      <!-- NAV -->
      <nav style="display:flex; align-items:center; justify-content:space-between; padding:26px 72px; border-bottom:1px solid #E2D8C8; position:sticky; top:0; z-index:50; background:rgba(244,238,227,.9); backdrop-filter:blur(10px);">
        <div style="display:flex; align-items:center; gap:11px;">
          <img src="/assets/icpe-globe.png" alt="ICPE" style="height:40px; width:auto; display:block;" />
          <div style="font-size:19px; font-weight:800; letter-spacing:-.02em;">ICPE Mission <span style="font-weight:400; color:#6B615A;">Warszawa</span></div>
        </div>
        <div class="nav-links" style="display:flex; align-items:center; gap:30px; font-size:15px; font-weight:500;">
          <a href="#wspolnota" style="color:inherit; text-decoration:none;"><span data-pl>Wspólnota</span><span data-en>Community</span></a>
          <a href="#mapa" style="color:inherit; text-decoration:none;"><span data-pl>Świat</span><span data-en>World</span></a>
          <a href="#polska" style="color:inherit; text-decoration:none;"><span data-pl>Polska</span><span data-en>Poland</span></a>
          <a href="#events" style="color:inherit; text-decoration:none;"><span data-pl>Wydarzenia</span><span data-en>Events</span></a>
        </div>
        <div style="display:flex; align-items:center; gap:18px; margin-left:32px;">
          <div style="display:flex; align-items:center; gap:8px; font-family:'Space Mono',monospace; font-size:13px;">
            <button data-langbtn="pl" style="background:none; border:none; font:inherit; color:inherit; padding:0;">PL</button>
            <span style="color:#C4B8A6;">/</span>
            <button data-langbtn="en" style="background:none; border:none; font:inherit; color:inherit; padding:0;">EN</button>
          </div>
          <a href="#kontakt" class="js-mail" data-mail="d2Fyc3phd2FAaWNwZW1pc3Npb24ucGw=" data-subject="Kontakt — ICPE Mission Warszawa" style="display:inline-flex; padding:11px 20px; border-radius:100px; background:#241E1A; color:#F4EEE3; font-size:14px; font-weight:600; text-decoration:none;"><span data-pl>Napisz do nas</span><span data-en>Get in touch</span></a>
        </div>
      </nav>

      <!-- HERO -->
      <header class="hero" style="padding:76px 72px 64px; display:grid; grid-template-columns:1.45fr 1fr; gap:56px; align-items:center;">
        <div>
          <div style="display:flex; align-items:center; gap:16px; font-family:'Space Mono',monospace; font-size:13px; letter-spacing:.1em; text-transform:uppercase; color:#A0724F; margin-bottom:34px;">
            <span style="width:46px; height:1px; background:#C0603C;"></span>
            <span data-pl>Instytut Ewangelizacji Świata · od 1985</span><span data-en>Institute for World Evangelisation · since 1985</span>
          </div>
          <h1 style="margin:0; font-size:74px; line-height:0.98; letter-spacing:-.035em; font-weight:800;">
            <span data-pl>W <em style="font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; color:#C0603C;">wieczerniku</em> codziennego życia.</span>
            <span data-en>In the <em style="font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; color:#C0603C;">Upper Room</em> of everyday life.</span>
          </h1>
          <p style="margin:28px 0 0; font-size:19px; line-height:1.5; color:#4A4038; max-width:48ch;">
            <span data-pl>Jesteśmy międzynarodową katolicką wspólnotą misyjną zaangażowaną w dzieła ewangelizacji i miłosierdzia na wszystkich kontynentach. Połączyło nas pragnienie przemiany świata przez radość Ewangelii.</span>
            <span data-en>We are an international Catholic missionary community engaged in works of evangelisation and mercy on every continent. We are united by a desire to transform the world through the joy of the Gospel.</span>
          </p>
          <div class="hero-cta" style="display:flex; gap:14px; margin-top:38px;">
            <a href="#mapa" style="display:inline-flex; align-items:center; gap:9px; padding:16px 28px; border-radius:100px; background:#241E1A; color:#F4EEE3; font-size:16px; font-weight:600; text-decoration:none;"><span data-pl>Zobacz naszą mapę</span><span data-en>See our map</span></a>
            <a href="#wspolnota" style="display:inline-flex; align-items:center; gap:9px; padding:16px 28px; border-radius:100px; background:transparent; color:#241E1A; border:1px solid #C9BCA9; font-size:16px; font-weight:600; text-decoration:none;"><span data-pl>Poznaj wspólnotę</span><span data-en>Meet the community</span></a>
          </div>
        </div>
        <aside style="border-left:2px solid #C0603C; padding:6px 0 6px 34px;">
          <p style="margin:0; font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; font-size:29px; line-height:1.34; color:#3A3028;">
            <span data-pl>„Bo dla was jest obietnica i dla dzieci waszych, i dla wszystkich, którzy są daleko, a których Pan, Bóg nasz, powoła…"</span>
            <span data-en>“For the promise is for you, for your children, and for all who are far away…”</span>
          </p>
          <div style="margin-top:20px; font-family:'Space Mono',monospace; font-size:12px; letter-spacing:.1em; text-transform:uppercase; color:#A0724F;"><span data-pl>Dz 2,39 · Dzieje Apostolskie</span><span data-en>Acts 2:39</span></div>
        </aside>
      </header>

      <!-- HERO IMAGE — zdjęcia i rotacja sterowane z ustawień (Personal OS). -->
      <div style="padding:0 72px 20px;">
        <div class="hero-slides" data-hero-slides style="position:relative; height:420px; border-radius:16px; border:1px solid #E2D8C8; overflow:hidden;">
          {heroImages.map((img, i) => (
            <img
              class={`hero-slide${i === 0 ? ' is-on' : ''}`}
              src={img.url}
              alt={img.alt || 'ICPE Mission'}
              style={`object-position:${img.position || 'center'};`}
            />
          ))}
        </div>
      </div>

      <!-- TICKER -->
      <div style="padding:22px 72px 60px; border-bottom:1px solid #E2D8C8;">
        <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:.04em; color:#8A7F73; line-height:2;">
          Bangalore · Bogotá · Kota Kinabalu · Kraków · Kuala Lumpur · Kumasi · Lublin · Malta · Manila · Mannheim · Mysore · Oregon · Partinico · Seul · Singapur · Sydney · Warszawa · Wellington
        </div>
      </div>

      <!-- ETHOS -->
      <section id="wspolnota" class="ethos" style="padding:80px 72px; display:grid; grid-template-columns:1.15fr 1fr; gap:72px;">
        <div>
          <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:.14em; text-transform:uppercase; color:#A0724F; margin-bottom:24px;"><span data-pl>Kim jesteśmy</span><span data-en>Who we are</span></div>
          <!-- Rotator cytatów. Pierwszy (założyciele) zawsze na starcie.
               Kolejne cytaty: dodaj następne figure.quote przed div.quote-dots. -->
          <div class="quotes" data-quotes>
            <figure class="quote is-active" style="margin:0;">
              <p style="margin:0; font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; font-size:27px; line-height:1.36; color:#3A3028;">
                <span data-pl>„Wspólnota ICPE urodziła się z ziarenka Bożej obietnicy na małej wyspie na Morzu Śródziemnym. Kiedy zebrali się ludzie gotowi żyć tą obietnicą, zobaczyliśmy otwierające się drzwi — i dzięki łasce z wysoka dzisiaj docieramy do ludzi w potrzebie na całym świecie. Przyjdź i dołącz do nas!"</span>
                <span data-en>“The ICPE Community was born from the seed of God's promise on a small island in the Mediterranean. When people gathered, ready to live that promise, we saw doors open, and by grace from on high, today we reach people in need around the world. Come and join us!”</span>
              </p>
              <div style="display:flex; align-items:center; gap:16px; margin-top:28px;">
                <img src="/uploads/462623044_7856737674427104_2359881754499323139_n.jpg" alt="Anna i Mario Cappello" style="width:76px; height:76px; border-radius:50%; object-fit:cover; object-position:center 30%; border:2px solid #E2D8C8; flex:0 0 auto;" />
                <div>
                  <div style="font-size:17px; font-weight:700; letter-spacing:-.01em;">Anna &amp; Mario Cappello</div>
                  <div style="font-family:'Space Mono',monospace; font-size:12px; letter-spacing:.04em; text-transform:uppercase; color:#A0724F; margin-top:3px;"><span data-pl>Założyciele · Malta</span><span data-en>Founders · Malta</span></div>
                </div>
              </div>
            </figure>

            <figure class="quote" style="margin:0;">
              <p style="margin:0; font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; font-size:27px; line-height:1.36; color:#3A3028;">
                <span data-pl>„ICPE jest dla mnie szkołą pastoralnego nawrócenia: odwagi ewangelizacji, komplementarności charyzmatów i posług, współpracy świeckich i duchownych, misyjnej wspólnoty rozeznającej znaki czasu. Jednocześnie jest to duchowa oaza: środowisko wsparcia i wzajemnej pomocy, dzielenia trosk i radości, dom modlitwy i spotkania, pracy i świętowania."</span>
                <span data-en>“For me, ICPE is a school of pastoral conversion: the courage of evangelization, the complementarity of charisms and ministries, the collaboration of lay and clergy, and a missionary community discerning the signs of the times. At the same time, it is a spiritual oasis: an environment of support and mutual assistance, of shared concerns and joys, a house of prayer and encounter, of work and celebration.”</span>
              </p>
              <div style="display:flex; align-items:center; gap:16px; margin-top:28px;">
                <img src="/uploads/ks-pawlowski.jpg" alt="ks. Sławomir Pawłowski SAC" style="width:76px; height:76px; border-radius:50%; object-fit:cover; object-position:center 25%; border:2px solid #E2D8C8; flex:0 0 auto;" />
                <div>
                  <div style="font-size:17px; font-weight:700; letter-spacing:-.01em;"><span data-pl>ks. Sławomir Pawłowski SAC</span><span data-en>fr. Sławomir Pawłowski SAC</span></div>
                  <div style="font-family:'Space Mono',monospace; font-size:12px; letter-spacing:.04em; text-transform:uppercase; color:#A0724F; margin-top:3px;"><span data-pl>Doradca ICPE Mission Polska</span><span data-en>Spiritual advisor to the ICPE Mission Poland</span></div>
                </div>
              </div>
            </figure>

            <figure class="quote" style="margin:0;">
              <p style="margin:0; font-family:'Instrument Serif',serif; font-style:italic; font-weight:400; font-size:27px; line-height:1.36; color:#3A3028;">
                <span data-pl>„Pod wieloma względami ICPE ugruntowało moją drogę z Bogiem. Tutaj uczę się, jak stawać się człowiekiem według Bożego serca i uczę się tego do dziś. ICPE stworzyło dla mnie tę przestrzeń poprzez formację, uwielbienie i opiekę duszpasterską. To przygotowało mnie do kochania i służenia Jego ludowi w Polsce już przez ponad 16 lat."</span>
                <span data-en>“In many ways the ICPE grounded me in my walk with God. Here, I learn how to become a man after God's heart and I am still learning till today. For me ICPE created that space, through the teachings, worship and pastoral care and structures, that helped me grow to be a man after God's heart. This prepared me to love and serve his people in Poland for more than 16 years.”</span>
              </p>
              <div style="display:flex; align-items:center; gap:16px; margin-top:28px;">
                <img src="/uploads/john-paul.jpg" alt="John Paul" style="width:76px; height:76px; border-radius:50%; object-fit:cover; object-position:48% 27%; border:2px solid #E2D8C8; flex:0 0 auto;" />
                <div>
                  <div style="font-size:17px; font-weight:700; letter-spacing:-.01em;">John Paul</div>
                  <div style="font-family:'Space Mono',monospace; font-size:12px; letter-spacing:.04em; text-transform:uppercase; color:#A0724F; margin-top:3px;"><span data-pl>ICPE Mission Warszawa</span><span data-en>ICPE Mission Warsaw</span></div>
                </div>
              </div>
            </figure>

            <div class="quote-dots" role="tablist" aria-label="Cytaty"></div>
          </div>

          <!-- Statystyki — pod cytatami, jeden rząd, ściśnięte komórki -->
          <div class="stats" style="display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:#E2D8C8; border:1px solid #E2D8C8; border-radius:14px; overflow:hidden; margin-top:36px;">
            <div style="background:#F4EEE3; padding:14px 12px;"><div style="font-family:'Space Mono',monospace; font-size:24px; font-weight:700; letter-spacing:-.02em;">1985</div><div style="font-size:11px; color:#8A7F73; margin-top:3px;"><span data-pl>Malta · początek</span><span data-en>Malta · beginning</span></div></div>
            <div style="background:#F4EEE3; padding:14px 12px;"><div style="font-family:'Space Mono',monospace; font-size:24px; font-weight:700; letter-spacing:-.02em;">2002</div><div style="font-size:11px; color:#8A7F73; margin-top:3px;"><span data-pl>uznanie Watykanu</span><span data-en>Vatican recognition</span></div></div>
            <div style="background:#F4EEE3; padding:14px 12px;"><div style="font-family:'Space Mono',monospace; font-size:24px; font-weight:700; letter-spacing:-.02em;">23</div><div style="font-size:11px; color:#8A7F73; margin-top:3px;"><span data-pl>wspólnoty</span><span data-en>communities</span></div></div>
            <div style="background:#F4EEE3; padding:14px 12px;"><div style="font-family:'Space Mono',monospace; font-size:24px; font-weight:700; letter-spacing:-.02em;">6</div><div style="font-size:11px; color:#8A7F73; margin-top:3px;"><span data-pl>kontynentów</span><span data-en>continents</span></div></div>
          </div>
        </div>
        <div class="ethos-right" style="padding-top:42px;">
          <p style="margin:0 0 20px; font-size:17px; line-height:1.6; color:#4A4038;">
            <span data-pl>Instytut Ewangelizacji Świata – ICPE Mission powstał na Malcie w 1985 roku. Pod koniec lat 80. i przez całe lata 90. doświadczyliśmy znacznego rozwoju i ekspansji. W wielu krajach na całym świecie powstały Szkoły i Centra Misyjne oraz rozmaite inicjatywy ewangelizacyjne.</span>
            <span data-en>The Institute for World Evangelisation – ICPE Mission was founded in Malta in 1985. During the late 1980s and throughout the 1990s, the ICPE Mission experienced significant growth and expansion. Various Schools of Mission and evangelistic initiatives were launched in numerous countries worldwide.</span>
          </p>
          <p style="margin:0 0 20px; font-size:17px; line-height:1.6; color:#4A4038;">
            <span data-pl>Dzisiaj wspólnota ICPE składa się ze świeckich i duchownych misjonarzy, którzy głoszą Dobrą Nowinę na każdym kontynencie. Od dżungli po miasta, od Starego Świata po Nowy, poprzez szkoły formacyjne, działalność misyjną, placówki opieki zdrowotnej i multimedia, szerzymy radość Ewangelii wszędzie tam, gdzie Bóg nas posłał, stale dostosowując się do zmieniających się okoliczności.</span>
            <span data-en>Today, ICPE Mission comprises lay missionaries and priests sharing the Good News on every continent. From jungles to cities, from the old world to the new, through schools of formation, outreaches, healthcare facilities, and multimedia, the ICPE Mission has spread the joy of the Gospel wherever God sent them, constantly adapting to ever-changing circumstances.</span>
          </p>
          <p style="margin:0; font-size:17px; line-height:1.6; color:#4A4038;">
            <span data-pl>W 2002 r., w uroczystość Zesłania Ducha Świętego, Stolica Apostolska nadała naszej wspólnocie status międzynarodowego stowarzyszenia wiernych na prawie papieskim. Od 1998 roku wspólnota ICPE działa również w Polsce.</span>
            <span data-en>On May 19, 2002, the Feast of Pentecost, the Holy See bestowed upon the Institute for World Evangelisation - ICPE Mission the status of International Association of Christ's Faithful with Pontifical Right, affirming its commitment to the universal mission of the Church. Since 1998, the ICPE community has also been present in Poland.</span>
          </p>
        </div>
      </section>

      <!-- PILLARS -->
      <section style="padding:0 72px 84px;">
        <div class="pillars" style="display:grid; grid-template-columns:repeat(4,1fr); gap:0; border-top:1px solid #241E1A;">
          <div style="padding:30px 26px 0; border-right:1px solid #E2D8C8;"><div style="font-family:'Space Mono',monospace; font-size:12px; color:#A0724F;">01</div><div style="width:22px; height:22px; border-radius:50%; background:#C0603C; margin:26px 0 16px;"></div><div style="font-size:22px; font-weight:700; letter-spacing:-.01em;"><span data-pl>Uwielbienie</span><span data-en>Worship</span></div><p style="margin:8px 0 0; font-size:14px; line-height:1.5; color:#6B615A;"><span data-pl>Modlitwa i adoracja jako źródło wszystkiego, co robimy.</span><span data-en>Prayer and adoration as the source of all we do.</span></p></div>
          <div style="padding:30px 26px 0; border-right:1px solid #E2D8C8;"><div style="font-family:'Space Mono',monospace; font-size:12px; color:#A0724F;">02</div><div style="width:22px; height:22px; background:#C0603C; margin:26px 0 16px;"></div><div style="font-size:22px; font-weight:700; letter-spacing:-.01em;"><span data-pl>Ewangelizacja</span><span data-en>Evangelisation</span></div><p style="margin:8px 0 0; font-size:14px; line-height:1.5; color:#6B615A;"><span data-pl>Dzielenie się wiarą prosto, po ludzku, tam gdzie żyjemy.</span><span data-en>Sharing faith simply, humanly, right where we live.</span></p></div>
          <div style="padding:30px 26px 0; border-right:1px solid #E2D8C8;"><div style="font-family:'Space Mono',monospace; font-size:12px; color:#A0724F;">03</div><div style="width:22px; height:22px; border-radius:50%; border:5px solid #C0603C; box-sizing:border-box; margin:26px 0 16px;"></div><div style="font-size:22px; font-weight:700; letter-spacing:-.01em;"><span data-pl>Wspólnota</span><span data-en>Community</span></div><p style="margin:8px 0 0; font-size:14px; line-height:1.5; color:#6B615A;"><span data-pl>Życie razem: małe grupy, dom, codzienność i przyjaźń.</span><span data-en>Life together: small groups, home, the everyday, friendship.</span></p></div>
          <div style="padding:30px 26px 0;"><div style="font-family:'Space Mono',monospace; font-size:12px; color:#A0724F;">04</div><div style="width:22px; height:22px; background:#C0603C; transform:rotate(45deg); margin:26px 0 16px;"></div><div style="font-size:22px; font-weight:700; letter-spacing:-.01em;"><span data-pl>Miłosierdzie</span><span data-en>Mercy</span></div><p style="margin:8px 0 0; font-size:14px; line-height:1.5; color:#6B615A;"><span data-pl>Konkretna miłość wobec ubogich i zranionych.</span><span data-en>Concrete love for the poor and the wounded.</span></p></div>
        </div>
      </section>

      <!-- MAP (dark) -->
      <section id="mapa" style="background:#201812; color:#EDE3D3; padding:80px 72px; border-radius:20px; margin:0 24px 24px;">
        <div class="map-head" style="display:flex; align-items:flex-end; justify-content:space-between; gap:24px; margin-bottom:44px; flex-wrap:wrap;">
          <div>
            <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:.14em; text-transform:uppercase; color:#C0603C; margin-bottom:18px;"><span data-pl>Jedna wspólnota · cały świat</span><span data-en>One community · one world</span></div>
            <h2 style="margin:0; font-size:56px; line-height:1; letter-spacing:-.03em; font-weight:800;"><span data-pl>Od Malty po Wellington.</span><span data-en>From Malta to Wellington.</span></h2>
          </div>
          <p style="margin:0; max-width:34ch; font-size:16px; line-height:1.55; color:rgba(237,227,211,.72);"><span data-pl>ICPE Warszawa to jedna z 23 wspólnot Instytutu Ewangelizacji Świata – ICPE Mission na świecie. Zobacz, gdzie jeszcze jesteśmy obecni.</span><span data-en>ICPE Warsaw is one of 23 communities of the Institute for World Evangelisation – ICPE Mission worldwide. See where else we are present.</span></p>
        </div>
        <WorldMap />
      </section>

      <!-- FAITH IN ACTION -->
      <section id="polska" style="padding:60px 72px 84px;">
        <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:.14em; text-transform:uppercase; color:#A0724F; margin-bottom:30px;"><span data-pl>Wiara w działaniu</span><span data-en>Faith in action</span></div>
        <div class="triptych" style="display:grid; grid-template-columns:repeat(3,1fr); gap:22px;">
          <figure style="margin:0;">
            <div style="height:440px; border-radius:16px; overflow:hidden; border:1px solid #E2D8C8;">
              <img src="/uploads/jametlene-reskp-BkhIxji_bJE-unsplash.jpg" alt="Budowanie wspólnoty" style="width:100%; height:100%; object-fit:cover; object-position:center 35%; display:block;" />
            </div>
            <figcaption style="margin-top:16px; display:flex; align-items:baseline; gap:10px;">
              <span style="font-family:'Space Mono',monospace; font-size:12px; color:#A0724F;">01</span>
              <span style="font-size:21px; font-weight:700; letter-spacing:-.01em;"><span data-pl>Budowanie wspólnoty</span><span data-en>Community building</span></span>
            </figcaption>
          </figure>
          <figure style="margin:0;">
            <div style="height:440px; border-radius:16px; overflow:hidden; border:1px solid #E2D8C8;">
              <img src="/uploads/476770027_625787609952534_2898397860552931423_n.jpg" alt="Dzieła miłosierdzia" style="width:100%; height:100%; object-fit:cover; object-position:center 40%; display:block;" />

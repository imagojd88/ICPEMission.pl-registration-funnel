    #site-root nav { padding: 20px 22px !important; }
    #site-root .hero { padding: 40px 22px !important; }
  }
</style>

<script is:inline>
  // E-mail antyspam: adres trzymany jako base64 w data-mail, mailto składany dopiero w JS,
  // więc w źródle HTML nie ma czytelnego wzorca „x@y" do zebrania przez boty.
  document.querySelectorAll('.js-mail').forEach((el) => {
    try {
      const email = atob(el.getAttribute('data-mail') || '');
      if (!email) return;
      const subj = el.getAttribute('data-subject');
      el.setAttribute('href', 'mailto:' + email + (subj ? '?subject=' + encodeURIComponent(subj) : ''));
      if (el.hasAttribute('data-showtext') && !el.textContent.trim()) el.textContent = email;
    } catch (e) { /* ignore */ }
  });

  // Przełącznik języka PL/EN — ustawia data-lang na kontenerze (CSS steruje widocznością).
  const root = document.getElementById('site-root');
  document.querySelectorAll('[data-langbtn]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const lng = btn.getAttribute('data-langbtn');
      if (root && lng) {
        root.setAttribute('data-lang', lng);
        document.documentElement.setAttribute('lang', lng);
      }
    });
  });
</script>

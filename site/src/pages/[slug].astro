---
import BaseLayout from '../layouts/BaseLayout.astro';
import Blocks from '../components/Blocks.astro';
import { getPages, getPage, type PageFull } from '../lib/api';

// Statyczne strony (o-nas, kontakt, …) — z /site/pages, bez „home" (to strona główna).
export async function getStaticPaths() {
  const pages = await getPages();
  const results = await Promise.all(
    pages
      .filter((p) => p.slug !== 'home')
      .map(async (p) => {
        const full = await getPage(p.slug);
        return full ? { params: { slug: p.slug }, props: { page: full } } : null;
      }),
  );
  return results.filter((r): r is { params: { slug: string }; props: { page: PageFull } } => r !== null);
}

const { page } = Astro.props;
---

<BaseLayout title={page.seoTitle || page.title} description={page.seoDesc || undefined} ogImage={page.ogImageUrl}>
  <article class="container page">
    <header class="page-head">
      <h1>{page.title}</h1>
    </header>
    <Blocks blocks={page.blocks} />
  </article>
</BaseLayout>

<style>
  .page {
    padding: 48px 20px 24px;
  }
  .page-head {
    max-width: 720px;
    margin: 0 auto 24px;
  }
  .page-head h1 {
    font-size: clamp(30px, 5vw, 44px);
    margin: 0;
  }
</style>

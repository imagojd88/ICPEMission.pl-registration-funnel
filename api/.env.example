# Database
DATABASE_URL="postgresql://icpe:icpe@localhost:5432/icpe_registration"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# Payments
PAYMENTS_MODE=mock

# Mail
MAIL_MODE=log

# Frontend URL (used in magic links, calendar links)
FRONTEND_URL="http://localhost:5173"
